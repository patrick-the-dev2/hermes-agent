      "source": [
        "import os, sys, json, time, shutil, subprocess, requests\n",
        "from google.colab import drive\n",
        "\n",
        "# --- CONFIGURATION ---\n",
        "TELEGRAM_BOT_TOKEN = \"8979391289:AAHG0gZQrlg92PZqHmmKYJ8FdzailJBwdZY\"\n",
        "TELEGRAM_USER_ID = 7741540586\n",
        "NVIDIA_API_KEY = \"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\"\n",
        "NVIDIA_MODEL_NAME = \"minimaxai/minimax-m3\"\n",
        "\n",
        "# --- STEP 1: PERSISTENCE & DRIVE ---\n",
        "print(\"🔗 Resetting Google Drive connection...\")\n",
        "# Force unmount to fix 'Transport endpoint is not connected'\n",
        "subprocess.run(\"fusermount -u /content/drive\", shell=True, capture_output=True)\n",
        "\n",
        "time.sleep(2)\n",
        "drive.mount('/content/drive', force_remount=True)\n",
        "\n",
        "hermes_drive_dir = \"/content/drive/MyDrive/HermesAgentData\"\n",
        "os.makedirs(hermes_drive_dir, exist_ok=True)\n",
        "local_hermes = os.path.expanduser(\"~/.hermes\")\n",
        "\n",
        "if not os.path.islink(local_hermes):\n",
        "    if os.path.exists(local_hermes): shutil.move(local_hermes, f\"{hermes_drive_dir}_old\")\n",
        "    os.symlink(hermes_drive_dir, local_hermes)\n",
        "\n",
        "# --- STEP 2: INSTALLATION ---\n",
        "if not shutil.which(\"hermes\"):\n",
        "    print(\"📦 Installing Hermes Agent...\")\n",
        "    subprocess.run(\"curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash\", shell=True)\n",
        "os.environ['PATH'] += os.pathsep + os.path.expanduser('~/.local/bin')\n",
        "\n",
        "# --- STEP 3: CONFIGURATION ---\n",
        "env_content = f\"\"\"NVIDIA_API_KEY={NVIDIA_API_KEY}\n",
        "TELEGRAM_BOT_TOKEN={TELEGRAM_BOT_TOKEN}\n",
        "TELEGRAM_ALLOWED_USERS={TELEGRAM_USER_ID}\n",
        "HERMES_GATEWAY_TELEGRAM_ENABLED=true\n",
        "GATEWAY_ALLOW_ALL_USERS=true\"\"\"\n",
        "\n",
        "with open(os.path.join(local_hermes, \".env\"), \"w\") as f: f.write(env_content)\n",
        "with open(os.path.join(local_hermes, \"config.yaml\"), \"w\") as f:\n",
        "    f.write(f'model:\\n  provider: \"nvidia\"\\n  default: \"{NVIDIA_MODEL_NAME}\"\\n')\n",
        "\n",
        "# --- STEP 4: START GATEWAY (Line Buffered) ---\n",
        "print(\"🚀 Starting Hermes Gateway...\")\n",
        "subprocess.run(\"pkill -f 'hermes gateway'\", shell=True)\n",
        "time.sleep(2)\n",
        "\n",
        "gateway_log = \"/content/gateway.log\"\n",
        "with open(gateway_log, \"w\") as log_file:\n",
        "    subprocess.Popen([\"stdbuf\", \"-oL\", \"hermes\", \"gateway\"], stdout=log_file, stderr=subprocess.STDOUT)\n",
        "\n",
        "time.sleep(8)\n",
        "print(f\"\\n✅ Hermes is running with {NVIDIA_MODEL_NAME}!\")"
      ],
